conky.config = {
    alignment = 'top_right',
    gap_x = 20,
    gap_y = 40,
    minimum_width = 340,
    maximum_width = 340,

    own_window = true,
    own_window_type = 'override',
    own_window_class = 'Conky',
    own_window_transparent = true,
    own_window_hints = 'undecorated,below,sticky,skip_taskbar,skip_pager',

    double_buffer = true,
    use_xft = true,
    font = 'Tahoma:size=11',
    xftalpha = 1.0,

    update_interval = 2,
    total_run_times = 0,

    draw_shades = false,
    draw_outline = false,
    draw_borders = false,
    draw_graph_borders = false,

    default_color = '#ffffff',
    color1 = '#cbd6e2',
    color2 = '#729fcf',
    color3 = '#ef2929',

    cpu_avg_samples = 2,
    net_avg_samples = 2,
    no_buffers = true,
};

conky.text = [[
${color2}${font Tahoma:bold:size=13}SYSTEM${font}${color}
${color1}${hr 2}${color}

Host:   ${nodename}
Kernel: ${kernel}
Uptime: ${uptime}

CPU:    ${cpu}% 
        ${cpubar 10,200 /}

RAM:    ${mem}/${memmax} 
        ${membar 10,200 /}

Root:   ${fs_used /}/${fs_size /}
        ${fs_bar 10,200 /}

Home:   ${fs_used /home}/${fs_size /home}
        ${fs_bar 10,200 /home}

${if_existing /sys/class/power_supply/BAT1}
Battery: ${battery_percent BAT1}%
${endif}

Down: ${downspeedf wlp1s0} KiB/s
Up:   ${upspeedf wlp1s0} KiB/s

${color2}${font Tahoma:bold:size=13}TASKS${font}${color}
${color1}${hr 2}${color}

${execi 60 ~/.local/bin/conky-taskwarrior}

${color2}${font Tahoma:bold:size=13}TIME${font}${color}
${color1}${hr 2}${color}

${time %A}
${time %d %B %Y}

${font Tahoma:bold:size=18}${time %H:%M:%S}${font}
]];
